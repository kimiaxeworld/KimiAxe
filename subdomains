<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KimiAxe — About, Contact & Support</title>
<link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;700&family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#000;--bg2:#0a0a0a;--bg3:#111;--border:#222;--border2:#333;--text:#fff;--muted:#666;--muted2:#999}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow-x:hidden;-webkit-font-smoothing:antialiased}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;border-bottom:1px solid var(--border);background:rgba(0,0,0,0.92);backdrop-filter:blur(20px)}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between}
.logo{font-family:'Geist Mono',monospace;font-size:1.1rem;font-weight:700;color:var(--text);text-decoration:none}
.logo span{color:var(--muted)}
.nav-right{display:flex;align-items:center;gap:8px}
.nav-back{color:var(--muted);text-decoration:none;font-size:0.8rem;padding:6px 12px;border-radius:6px;border:1px solid var(--border);transition:all 0.15s}
.nav-back:hover{color:var(--text);border-color:var(--border2)}
.btn-w{background:var(--text);color:var(--bg);padding:7px 16px;border-radius:6px;font-weight:600;font-size:0.82rem;text-decoration:none}
.btn-w:hover{background:#e5e5e5}

/* TABS */
.tabs-bar{border-bottom:1px solid var(--border);background:var(--bg);padding-top:56px;position:sticky;top:56px;z-index:90}
.tabs-inner{max-width:1200px;margin:0 auto;padding:0 24px;display:flex;gap:0;overflow-x:auto}
.tab-btn{padding:14px 20px;font-size:0.82rem;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all 0.15s;background:none;border-top:none;border-left:none;border-right:none;font-family:'DM Sans',sans-serif;font-weight:500;white-space:nowrap}
.tab-btn:hover{color:var(--text)}
.tab-btn.active{color:var(--text);border-bottom-color:var(--text)}

/* PAGES */
.page{display:none;max-width:1200px;margin:0 auto;padding:56px 24px 100px}
.page.active{display:block}

/* PAGE HERO */
.ph{padding:56px 0 48px;border-bottom:1px solid var(--border);margin-bottom:56px}
.pl{font-family:'Geist Mono',monospace;font-size:0.68rem;color:var(--muted);letter-spacing:3px;text-transform:uppercase;margin-bottom:12px}
.pt{font-family:'Instrument Serif',serif;font-size:clamp(2.5rem,5vw,3.8rem);letter-spacing:-1.5px;line-height:1.05;margin-bottom:14px}
.pt em{font-style:italic;color:var(--muted)}
.pd{font-size:0.95rem;color:var(--muted);max-width:480px;line-height:1.75}

/* GRID */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:32px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}

/* CARD */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:28px;transition:border-color 0.2s}
.card:hover{border-color:var(--border2)}
.ci{font-size:1.5rem;margin-bottom:14px}
.ct{font-size:0.95rem;font-weight:700;margin-bottom:8px}
.cd{font-size:0.82rem;color:var(--muted);line-height:1.7;margin-bottom:16px}
.cl{font-size:0.78rem;color:var(--text);text-decoration:none;font-family:'Geist Mono',monospace;display:inline-flex;align-items:center;gap:6px;border-bottom:1px solid var(--border2);padding-bottom:2px;transition:border-color 0.15s}
.cl:hover{border-color:var(--text)}

/* FORM */
.fg{margin-bottom:20px}
.fl{font-size:0.72rem;color:var(--muted2);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;display:block;font-family:'Geist Mono',monospace}
.fi{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:12px 16px;color:var(--text);font-size:0.88rem;font-family:'DM Sans',sans-serif;outline:none;transition:border-color 0.15s}
.fi:focus{border-color:var(--border2)}
.fi::placeholder{color:var(--muted)}
textarea.fi{resize:vertical;min-height:120px}
select.fi{cursor:pointer;-webkit-appearance:none;appearance:none}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.sbtn{background:var(--text);color:var(--bg);padding:13px 28px;border-radius:8px;font-weight:700;font-size:0.88rem;border:none;cursor:pointer;transition:all 0.15s;font-family:'DM Sans',sans-serif}
.sbtn:hover{background:#e5e5e5;transform:translateY(-1px)}
.obtn{background:transparent;color:var(--text);padding:13px 28px;border-radius:8px;font-weight:500;font-size:0.88rem;border:1px solid var(--border2);cursor:pointer;transition:all 0.15s;font-family:'DM Sans',sans-serif;text-decoration:none;display:inline-block}
.obtn:hover{border-color:#555}

/* DIVIDER */
.div{height:1px;background:var(--border);margin:48px 0}
.div-label{display:flex;align-items:center;gap:16px;margin:48px 0}
.div-label span{font-family:'Geist Mono',monospace;font-size:0.65rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;white-space:nowrap}
.div-label::before,.div-label::after{content:'';flex:1;height:1px;background:var(--border)}

/* SECTION */
.sec{margin-bottom:56px}
.sl{font-family:'Geist Mono',monospace;font-size:0.68rem;color:var(--muted);letter-spacing:3px;text-transform:uppercase;margin-bottom:10px}
.st{font-family:'Instrument Serif',serif;font-size:clamp(1.8rem,3vw,2.5rem);letter-spacing:-1px;margin-bottom:32px}
.st em{font-style:italic;color:var(--muted)}

/* TEAM */
.team-card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:24px;text-align:center;transition:border-color 0.2s}
.team-card:hover{border-color:var(--border2)}
.avatar{width:72px;height:72px;border-radius:50%;background:var(--bg3);border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin:0 auto 16px}
.tm-name{font-size:0.95rem;font-weight:700;margin-bottom:4px}
.tm-role{font-size:0.75rem;color:var(--muted);font-family:'Geist Mono',monospace;letter-spacing:1px;text-transform:uppercase}

/* TIMELINE */
.timeline{position:relative;padding-left:32px}
.timeline::before{content:'';position:absolute;left:0;top:0;bottom:0;width:1px;background:var(--border)}
.tl-item{position:relative;padding-bottom:36px}
.tl-item::before{content:'';position:absolute;left:-36px;top:4px;width:9px;height:9px;border-radius:50%;background:var(--bg);border:1px solid var(--border2)}
.tl-year{font-family:'Geist Mono',monospace;font-size:0.68rem;color:var(--muted);letter-spacing:2px;margin-bottom:6px}
.tl-title{font-size:0.95rem;font-weight:700;margin-bottom:4px}
.tl-desc{font-size:0.82rem;color:var(--muted);line-height:1.6}

/* VALUES */
.val-item{padding:24px;border-left:2px solid var(--border);margin-bottom:20px;transition:border-color 0.2s}
.val-item:hover{border-left-color:var(--text)}
.val-title{font-size:0.95rem;font-weight:700;margin-bottom:6px}
.val-desc{font-size:0.82rem;color:var(--muted);line-height:1.7}

/* STATUS */
.status-item{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--border)}
.status-item:last-child{border-bottom:none}
.status-left{display:flex;align-items:center;gap:12px}
.status-dot{width:8px;height:8px;border-radius:50%}
.dot-green{background:#22c55e;box-shadow:0 0 8px #22c55e}
.dot-yellow{background:#eab308;box-shadow:0 0 8px #eab308}
.dot-red{background:#ef4444;box-shadow:0 0 8px #ef4444}
.status-name{font-size:0.88rem;font-weight:500}
.status-badge{font-size:0.72rem;font-family:'Geist Mono',monospace;padding:4px 10px;border-radius:4px;letter-spacing:1px}
.badge-op{background:rgba(34,197,94,0.1);color:#22c55e;border:1px solid rgba(34,197,94,0.2)}
.badge-deg{background:rgba(234,179,8,0.1);color:#eab308;border:1px solid rgba(234,179,8,0.2)}

/* FAQ */
.faq-item{border-bottom:1px solid var(--border);padding:20px 0;cursor:pointer}
.faq-q{display:flex;justify-content:space-between;align-items:center;font-size:0.92rem;font-weight:600}
.faq-icon{color:var(--muted);font-size:1.2rem;transition:transform 0.2s}
.faq-a{font-size:0.82rem;color:var(--muted);line-height:1.7;max-height:0;overflow:hidden;transition:max-height 0.3s ease,padding 0.3s}
.faq-item.open .faq-a{max-height:200px;padding-top:12px}
.faq-item.open .faq-icon{transform:rotate(45deg)}

/* CONTACT CHANNELS */
.ch-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:40px}
.ch-card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:24px;display:flex;align-items:center;gap:16px;text-decoration:none;transition:border-color 0.2s}
.ch-card:hover{border-color:var(--border2)}
.ch-icon{font-size:2rem;width:48px;text-align:center;flex-shrink:0}
.ch-name{font-size:0.92rem;font-weight:700;color:var(--text);margin-bottom:2px}
.ch-handle{font-size:0.75rem;color:var(--muted);font-family:'Geist Mono',monospace}

/* SUCCESS MSG */
.success-msg{display:none;background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:8px;padding:16px 20px;font-size:0.85rem;color:#22c55e;margin-top:16px}

/* FOOTER */
footer{border-top:1px solid var(--border);padding:36px 24px;margin-top:80px}
.footer-inner{max-width:1200px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:20px}
.footer-links{display:flex;gap:20px;flex-wrap:wrap}
.footer-links a{font-size:0.75rem;color:var(--muted);text-decoration:none}
.footer-links a:hover{color:var(--text)}
.fc{font-size:0.75rem;color:var(--muted)}

@media(max-width:768px){.g2,.g3,.g4,.fr,.ch-grid{grid-template-columns:1fr}.tabs-inner{overflow-x:auto}}
</style>
</head>
